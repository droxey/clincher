# {{ ansible_managed }}
# Clawvisor environment — secrets injected from Ansible vault.
# Mode 0600, owned by root. Never committed to version control.

DATABASE_DRIVER=postgres
DATABASE_URL=postgresql://clawvisor:{{ clawvisor_db_password }}@clawvisor-db:5432/clawvisor?sslmode=disable
JWT_SECRET={{ clawvisor_jwt_secret }}
VAULT_KEY={{ clawvisor_vault_key }}
AUTH_MODE={{ clawvisor_auth_mode }}
PORT={{ clawvisor_port }}
{% if clawvisor_allowed_emails is defined and clawvisor_allowed_emails | length > 0 %}
ALLOWED_EMAILS={{ clawvisor_allowed_emails | join(',') }}
{% endif %}
{% if clawvisor_google_client_id is defined %}
GOOGLE_CLIENT_ID={{ clawvisor_google_client_id }}
{% endif %}
{% if clawvisor_google_client_secret is defined %}
GOOGLE_CLIENT_SECRET={{ clawvisor_google_client_secret }}
{% endif %}
{% if clawvisor_public_url is defined %}
PUBLIC_URL={{ clawvisor_public_url }}
{% endif %}
