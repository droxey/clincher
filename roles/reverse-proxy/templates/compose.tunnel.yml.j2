services:
  cloudflared:
    image: cloudflare/cloudflared:{{ cloudflared_version }}
    container_name: openclaw-tunnel
    command: tunnel run
    environment:
      TUNNEL_TOKEN: "${TUNNEL_TOKEN}"
    networks:
      - proxy-net
      - egress-net
    read_only: true
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    security_opt:
      - no-new-privileges:true
    restart: unless-stopped

networks:
  proxy-net:
    external: true
    name: openclaw_proxy-net
  egress-net:
    external: true
    name: openclaw_egress-net
