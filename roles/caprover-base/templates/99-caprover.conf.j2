# CapRover node system tuning
vm.swappiness = {{ caprover_swappiness }}
fs.inotify.max_user_watches = {{ caprover_inotify_max_watches }}
fs.inotify.max_user_instances = {{ caprover_inotify_max_instances }}
net.core.somaxconn = {{ caprover_somaxconn }}
net.ipv4.tcp_max_syn_backlog = 65535
net.ipv4.ip_local_port_range = 1024 65535
net.ipv4.tcp_tw_reuse = 1
net.ipv4.tcp_fin_timeout = 15
