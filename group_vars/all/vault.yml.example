---
# Copy this file to vault.yml and encrypt with: ansible-vault encrypt vault.yml
#
# These values are sensitive — never commit vault.yml unencrypted.
# ALL secrets below MUST be filled before running the playbook.

# ── LLM Provider API Keys (required) ────────────────────────────────
anthropic_api_key: "sk-ant-your-key-here"
voyage_api_key: "pa-your-key-here"
# openai_api_key: "sk-your-key-here"

# ── Optional OpenClaw Runtime Env (for Clawtomaton, etc.) ───────────
# Set only the variables you actually need; each one is exposed to the
# OpenClaw container at runtime via /opt/openclaw/.env.
# openclaw_extra_env:
#   BASE_RPC_URL: "https://mainnet.base.org"
#   # Optional Clawtomaton extras:
#   # CONWAY_API_KEY: "..."
#   # UNISWAP_API_KEY: "..."
#   # WAYFINDER_API_KEY: "..."
#   # HERD_ACCESS_TOKEN: "..."
#   # WALLETCONNECT_PROJECT_ID: "..."

# ── Secrets (REQUIRED — generate each with: openssl rand -hex 32) ────
# These must be set before the first run and kept stable across re-runs.
# Changing them after deployment breaks auth tokens and unreadable backups.
litellm_master_key: ""
gateway_token: ""
backup_encryption_key: ""

# ── Agent Orchestrator ─────────────────────────────────────────────
# Required when agent_orchestrator_enabled: true
# Create a fine-grained PAT at https://github.com/settings/tokens with
# repo, issues, and pull-request permissions for target repositories.
github_token: "ghp_your-token-here"

# ── Channel Tokens ──────────────────────────────────────────────────
telegram_bot_token: "YOUR_TELEGRAM_BOT_TOKEN"

# ── Reverse Proxy (if using Cloudflare Tunnel) ──────────────────────
# tunnel_token: "YOUR_TUNNEL_TOKEN"

# ── Monitoring (Grafana on separate monitoring VPS) ──────────────────
# Only needed when deploying caprover-playbook.yml for external monitoring.
# Generate with: openssl rand -base64 24
# grafana_admin_password: ""
